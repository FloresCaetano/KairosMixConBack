# Frontend environment variables (Vite)
#
# Default behavior:
# - If VITE_API_BASE_URL is not set, the app will call '/api/v1' (same-origin).
#   In dev, Vite proxies '/api' to 'http://localhost:8080' (see vite.config.js).
#
# For production (e.g., GitHub Pages), you MUST set this to your backend URL:
# VITE_API_BASE_URL=https://your-backend-domain/api/v1

# VITE_API_BASE_URL=http://localhost:8080/api/v1

